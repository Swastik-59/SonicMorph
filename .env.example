# SonicMorph Environment Variables
# Copy this file to .env and fill in your values.

# Jamendo API credentials (required if jamendo source is enabled)
JAMENDO_CLIENT_ID=your_jamendo_client_id_here

# AcoustID API key for audio fingerprinting (required for deduplication)
ACOUSTID_API_KEY=your_acoustid_api_key_here

# MusicBrainz user agent string (required for metadata lookups)
MUSICBRAINZ_USER_AGENT=SonicMorph/1.0 (your_email@example.com)
